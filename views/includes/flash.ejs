<% if(success && success.length) { %>
  <div class="alert alert-success col-10 offset-1 col-md-6 offset-md-3 alert-dismissible fade show mt-4 shadow-sm" role="alert" style="border-radius: 12px;">
     <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if(error && error.length) { %>
  <div class="alert alert-danger col-10 offset-1 col-md-6 offset-md-3 alert-dismissible fade show mt-4 shadow-sm" role="alert" style="border-radius: 12px;">
     <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>