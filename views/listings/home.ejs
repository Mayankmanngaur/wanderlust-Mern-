<% layout("/layouts/boilerplate") -%>

<style>
  /* Page Title Styling */
  .page-title {
    color: #222222;
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  /* Card Container Link Wrapper */
  .listing-link {
    transition: transform 0.2s ease-in-out;
  }

  /* Core Card Styling - Clean & Borderless */
  .custom-card {
    border: none !important;
    border-radius: 15px !important;
    overflow: hidden;
    background-color: transparent !important;
  }

  /* Image Container taaki hover par image bahar na nikle */
  .card-img-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 15px;
    aspect-ratio: 20 / 19; /* Airbnb jaisa perfect box ratio */
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
  }

  /* Card Image with Hover Zoom Effect */
  .custom-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  /* Link Wrapper Hover Effects */
  .listing-link:hover .custom-card-img {
    transform: scale(1.04); /* Halka sa elegant zoom */
  }

  /* Card Typography & Text Spacing */
  .custom-card-body {
    padding: 10px 2px 0 2px !important; /* Side padding kam taaki clean lage */
  }

  .card-listing-title {
    color: #222222;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis; /* Agar naam bohot bada ho toh ... ho jayega */
  }

  .card-listing-price {
    color: #555555;
    font-size: 0.9rem;
  }

  .price-bold {
    color: #222222;
    font-weight: 700;
  }

  /* Responsive Adjustments for Mobile Screens */
  @media (max-width: 576px) {
    .page-title {
      font-size: 1.5rem;
      margin-bottom: 1.5rem !important;
    }
    .card-img-wrapper {
      aspect-ratio: 4 / 3; /* Mobile par thodi wide image zyada badiya lagti hai */
    }
    .card-listing-title {
      font-size: 1rem;
    }
    .card-listing-price {
      font-size: 0.95rem;
    }
  }
</style>

<body>
  <div class="container my-4 my-sm-5">
    
    <h2 class="page-title mb-4 pb-1">Explore Listings</h2>
    
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
      
      <% for(let listing of listings){ %>
        <a href="/listings/<%= listing._id %>" class="col text-decoration-none listing-link">
          
          <div class="card h-100 custom-card">
            
            <div class="card-img-wrapper">
              <img src="<%= listing.image %>" class="custom-card-img" alt="listing image" loading="lazy">
            </div>
            
            <div class="card-body custom-card-body">
              <p class="card-text">
                <div class="card-listing-title text-capitalize"><%= listing.title %></div>
                
                <div class="card-listing-price">
                  <span class="price-bold">
                    <%= new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(listing.price) %>
                  </span>
                  <span>/ night</span>
                </div>
              </p>
            </div>

          </div>

        </a>
      <% } %>
      
    </div>
  </div>
</body>